// packages/schemas/memory.schema.json
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "memory_id": { "type": "string" },
    "memory_type": {
      "type": "string",
      "enum": ["request", "session", "brand", "agent", "qa", "trace"]
    },
    "scope": { "type": "string" },
    "agent_owner": { "type": "string" },
    "content": { "type": "object" },
    "summary": { "type": "string" },
    "source_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "ttl": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "readable_by": {
          "type": "array",
          "items": { "type": "string" }
        },
        "writable_by": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["readable_by", "writable_by"]
    }
  },
  "required": [
    "memory_id",
    "memory_type",
    "scope",
    "content",
    "permissions"
  ]
}