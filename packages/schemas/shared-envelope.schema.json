{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "agent_name": { "type": "string" },
    "agent_version": { "type": "string" },
    "request_id": { "type": "string" },
    "run_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["success", "partial", "failed"] },
    "skills_required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skills_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "memory_policy": {
      "type": "object",
      "properties": {
        "read_scopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "write_scopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "retrieval_mode": {
          "type": "string",
          "enum": ["none", "selective", "required"]
        }
      },
      "required": ["read_scopes", "write_scopes", "retrieval_mode"]
    },
    "memory_reads": {
      "type": "array",
      "items": { "type": "string" }
    },
    "memory_writes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "input_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "output": { "type": ["object", "null"] }
  },
  "required": [
    "agent_name",
    "request_id",
    "run_id",
    "status",
    "skills_required",
    "skills_used",
    "memory_policy",
    "memory_reads",
    "memory_writes",
    "output"
  ]
}